# Copiez ce fichier : cp .env.example .env
# ⚠️  Ne commitez JAMAIS votre .env (il est dans .gitignore)

# Votre clé privée MetaMask (sans 0x)
# → Utilisez UN COMPTE DÉDIÉ AUX TESTS, pas votre wallet principal !
PRIVATE_KEY=votre_cle_privee_ici

# URL RPC Sepolia — Créez un compte gratuit sur https://www.alchemy.com/
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/VOTRE_CLE_ALCHEMY

# Clé API Etherscan (gratuit) — https://etherscan.io/register
ETHERSCAN_API_KEY=votre_cle_etherscan

# Paramètres de votre token (optionnel — modifiez dans deploy.js sinon)
TOKEN_NAME=Mon Super Token
TOKEN_SYMBOL=MST
INITIAL_SUPPLY=1000
MAX_SUPPLY=10000
